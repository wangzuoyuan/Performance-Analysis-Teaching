# 复制本文件为 .env，填入你的 API Key 后再启动应用

# === Anthropic 模式（默认） ===
CHAT_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_BASE_URL=              # 留空使用官方地址；填兼容服务地址可切换第三方
ANTHROPIC_MODEL=claude-sonnet-4-6

# === OpenAI 兼容模式 ===
# CHAT_PROVIDER=openai
# OPENAI_API_KEY=your_api_key_here
# OPENAI_BASE_URL=              # 留空使用 api.openai.com；填兼容服务地址（含 /v1）
# OPENAI_MODEL=gpt-4o-mini

# === Docker / NAS 公网部署才需要；本地开发可全部留空 ===
# APP_PASSWORD：设了它才启用登录。外网（命中 PUBLIC_HOST）必须登录，内网 IP 直连免登录。建议设强密码。
APP_PASSWORD=
# PUBLIC_HOST：你的 DDNS 域名（如 xxx.synology.me）。只有该域名入口要求登录。
PUBLIC_HOST=
# SESSION_SECRET：会话签名密钥，留空则自动在数据目录生成并持久化（推荐留空）。
SESSION_SECRET=
# EXAM_TRACKER_DIR / EXAM_TRACKER_BACKUP_DIR：数据目录。Docker 镜像已默认 /data，本地通常无需设置。
# CORS_ORIGINS：同源部署无需设置；如需额外放行来源用逗号分隔。
